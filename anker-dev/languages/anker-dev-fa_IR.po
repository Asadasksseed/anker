msgid "انکر دِو"
msgstr "انکر دِو"

msgid "ویژگی‌ها"
msgstr "ویژگی‌ها"

msgid "تنظیمات"
msgstr "تنظیمات"

msgid "ذخیرهٔ تغییرات"
msgstr "ذخیرهٔ تغییرات"

msgid "فعال"
msgstr "فعال"

msgid "غیرفعال"
msgstr "غیرفعال"

msgid "وضعیت ویژگی"
msgstr "وضعیت ویژگی"

msgid "فعال‌سازی این ویژگی"
msgstr "فعال‌سازی این ویژگی"

msgid "مدت زمان (دقیقه)"
msgstr "مدت زمان (دقیقه)"

msgid "افزونهٔ Anker Dev مجموعه‌ای از ویژگی‌های توسعه‌دهنده برای ووکامرس را در اختیار شما قرار می‌دهد. در این صفحه می‌توانید هر ویژگی را به‌صورت مستقل فعال یا غیرفعال کنید و تنظیمات آن را تغییر دهید."
msgstr "افزونهٔ Anker Dev مجموعه‌ای از ویژگی‌های توسعه‌دهنده برای ووکامرس را در اختیار شما قرار می‌دهد. در این صفحه می‌توانید هر ویژگی را به‌صورت مستقل فعال یا غیرفعال کنید و تنظیمات آن را تغییر دهید."

msgid "در حال حاضر هیچ ویژگی‌ای ثبت نشده است."
msgstr "در حال حاضر هیچ ویژگی‌ای ثبت نشده است."

msgid "افزونهٔ Anker Dev برای کار به ووکامرس نیاز دارد. لطفاً ابتدا ووکامرس را نصب و فعال کنید."
msgstr "افزونهٔ Anker Dev برای کار به ووکامرس نیاز دارد. لطفاً ابتدا ووکامرس را نصب و فعال کنید."

msgid "لغو خودکار سفارش‌های پرداخت‌نشده"
msgstr "لغو خودکار سفارش‌های پرداخت‌نشده"

msgid "اگر سفارشی در ووکامرس ثبت شود و در وضعیت «در انتظار پرداخت» باقی بماند، پس از مدت زمان مشخص‌شده به‌صورت خودکار لغو خواهد شد."
msgstr "اگر سفارشی در ووکامرس ثبت شود و در وضعیت «در انتظار پرداخت» باقی بماند، پس از مدت زمان مشخص‌شده به‌صورت خودکار لغو خواهد شد."

#. translators: 1: min minutes, 2: max minutes
msgid "مقدار مجاز بین %1$s تا %2$s دقیقه است. مقدار پیش‌فرض ۱۵ دقیقه است."
msgstr "مقدار مجاز بین %1$s تا %2$s دقیقه است. مقدار پیش‌فرض ۱۵ دقیقه است."

#. translators: %s: number of minutes
msgid "سفارش به دلیل عدم پرداخت در مهلت %s دقیقه‌ای، توسط افزونهٔ Anker Dev به‌صورت خودکار لغو شد."
msgstr "سفارش به دلیل عدم پرداخت در مهلت %s دقیقه‌ای، توسط افزونهٔ Anker Dev به‌صورت خودکار لغو شد."
